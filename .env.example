# ============================================================
# Configuration AISCA-Cinema — FICHIER D'EXEMPLE
# Copiez ce fichier en `.env` et renseignez VOS valeurs.
# Ne committez JAMAIS votre vrai fichier `.env` (déjà gitignoré).
# ============================================================

# Clé API Google Gemini (IA générative)
# Obtenir une clé gratuite : https://aistudio.google.com/app/apikey
# ⚠️ Remplacez ce placeholder par votre clé (format AIza...).
GEMINI_API_KEY=VOTRE_CLE_API_GEMINI_ICI

# Modèle Gemini utilisé pour la génération
GEMINI_MODEL=gemini-2.5-flash

# Paramètres de génération (ajustables — voir evaluation/compare_params.py)
# Budget de sortie élevé car gemini-2.5-flash consomme des tokens en
# raisonnement interne ; 3072 garantit des réponses complètes (~200 mots).
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=3072

# Cache des réponses LLM (limitation des coûts API)
CACHE_ENABLED=true
MAX_CACHE_SIZE=100
